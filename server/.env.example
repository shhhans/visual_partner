# 复制为 server/.env 后填入真实值。.env 已被 .gitignore 忽略，不会入库。
#
# LLM / VL 走 OpenAI 兼容接口，供应商在此切换；ASR / TTS 走 DashScope 原生 SDK。

# ---------- OpenAI 兼容供应商（LLM / VL 默认共用） ----------
# 默认指向阿里 DashScope 兼容端点。OPENAI_API_KEY 留空时回落到 DASHSCOPE_API_KEY。
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_API_KEY=

# 模型名
LLM_MODEL=qwen-plus
VL_MODEL=qwen-vl-max

# 可选：LLM / VL 单独切到不同供应商时覆盖（留空则继承上面的 OPENAI_*）
# LLM_BASE_URL=
# LLM_API_KEY=
# VL_BASE_URL=
# VL_API_KEY=

# ---------- DashScope 原生 SDK（ASR / TTS，必填） ----------
DASHSCOPE_API_KEY=sk-xxx

# 可选：覆盖默认 ASR / TTS 模型与音色
# ASR_MODEL=paraformer-realtime-v2
# TTS_MODEL=cosyvoice-v2
# TTS_VOICE=longxiaochun_v2

# ---------- 可选工具 ----------
# 联网搜索；未配置时 web_search 降级 DuckDuckGo
TAVILY_API_KEY=

# ============================================================
# 切换示例：LLM + VL 改用 MiniMax（OpenAI 兼容），ASR/TTS 仍走 DashScope
# ------------------------------------------------------------
# OPENAI_BASE_URL=https://api.minimax.io/v1
# OPENAI_API_KEY=<your-minimax-key>
# LLM_MODEL=MiniMax-M3
# VL_MODEL=MiniMax-M3
# DASHSCOPE_API_KEY=sk-xxx   # ASR/TTS 仍需要
# ============================================================
