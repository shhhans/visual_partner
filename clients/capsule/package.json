{
  "name": "capsule",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "dist-electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k -n WEB,ELECTRON -c cyan,green \"npm:dev:web\" \"npm:dev:electron\"",
    "copy-vad-assets": "node scripts/copy-vad-assets.mjs",
    "predev:web": "npm run copy-vad-assets",
    "dev:web": "vite --host 127.0.0.1 --port 5173 --strictPort",
    "dev:electron": "wait-on http://127.0.0.1:5173 && npm run build:electron && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .",
    "build": "npm run build:web && npm run build:electron",
    "prebuild:web": "npm run copy-vad-assets",
    "build:web": "tsc -b && vite build",
    "build:electron": "esbuild electron/main.ts electron/preload.ts --bundle --platform=node --format=cjs --outdir=dist-electron --out-extension:.js=.cjs --external:electron",
    "start:electron": "npm run build && electron .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@ricky0123/vad-web": "^0.0.30",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.0",
    "onnxruntime-web": "^1.26.0",
    "postcss": "^8.5.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.8.0",
    "vite": "^7.0.0"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "concurrently": "^10.0.3",
    "cross-env": "^10.0.0",
    "electron": "^39.0.0",
    "esbuild": "^0.28.1",
    "wait-on": "^9.0.0"
  }
}
